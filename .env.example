# Postgres connection (Vercel Postgres / Neon). Copy to .env.local for local dev,
# and set the same in Vercel → Project → Settings → Environment Variables.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Shared secret the daily routine uses to push leads to /api/ingest.
INGEST_SECRET=change-me-to-a-long-random-string
