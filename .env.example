# Postgres connection (Vercel Postgres / Neon). Copy to .env.local for local dev,
# and set the same in Vercel → Project → Settings → Environment Variables.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Shared secret the daily routine uses to push leads to /api/ingest.
INGEST_SECRET=change-me-to-a-long-random-string

# Google sign-in (locked to @nearwork.co). Create an OAuth client in Google Cloud
# Console (consent screen = Internal). Authorized redirect URI:
#   https://leads.nearwork.co/api/auth/callback/google
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx
NEXTAUTH_URL=https://leads.nearwork.co
NEXTAUTH_SECRET=run-`openssl rand -base64 32`-to-generate
